# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for invite validation (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Platform admin: comma-separated user UUIDs who can access /platform-admin and boot users
# PLATFORM_ADMIN_USER_IDS=uuid1,uuid2

# App URL for password-reset emails and auth redirects (production: https://www.cacophony.us)
# NEXT_PUBLIC_APP_URL=https://www.cacophony.us
